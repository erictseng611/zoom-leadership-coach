# Claude API Access Method (choose one)
# Option 1: Direct Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option 2: AWS Bedrock (set USE_BEDROCK=true and run 'claude-up' first)
USE_BEDROCK=false
AWS_REGION=us-west-2

# Zoom API Credentials (optional - for direct transcript access)
# User-managed OAuth app. The redirect URI registered with your Zoom app must
# match http://localhost:${ZOOM_REDIRECT_PORT}/oauth/callback. Pick any free
# port; 8765 is a reasonable default.
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_REDIRECT_PORT=8765

# Application Settings
LOG_LEVEL=INFO
DEFAULT_RUN_TIME=20:00
